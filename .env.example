# OpenAI
OPENAI_API_KEY=your_openai_api_key

# Naver Open API (https://developers.naver.com)
NAVER_CLIENT_ID=your_client_id
NAVER_CLIENT_SECRET=your_client_secret

# Naver Search AD API (https://searchad.naver.com)
NAVER_AD_CUSTOMER_ID=your_customer_id
NAVER_AD_API_KEY=your_api_key
NAVER_AD_API_SECRET=your_api_secret

# Slack Bot (https://api.slack.com/apps)
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-token
SLACK_CHANNEL_ID=C0123456789
SLACK_CLIENT_NAME=wishket
SLACK_PUBLISHED_DB=data/wishket_published.json

# Google Drive (서비스 계정 인증)
GOOGLE_SERVICE_ACCOUNT_JSON=credentials/google_service_account.json
GOOGLE_DRIVE_FOLDER_ID=your_folder_id
